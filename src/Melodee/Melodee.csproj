<Project Sdk="Uno.Sdk">
    <PropertyGroup>
      <TargetFrameworks>net8.0-desktop;net8.0</TargetFrameworks>

        <OutputType>Exe</OutputType>
        <UnoSingleProject>true</UnoSingleProject>

        <!-- Display name -->
        <ApplicationTitle>Melodee</ApplicationTitle>
        <!-- App Identifier -->
        <ApplicationId>com.companyname.Melodee</ApplicationId>
        <!-- Versions -->
        <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
        <ApplicationVersion>1</ApplicationVersion>
        <!-- Package Publisher -->
        <ApplicationPublisher>O=Melodee</ApplicationPublisher>
        <!-- Package Description -->
        <Description>Melodee powered by Uno Platform.</Description>

        <!--
          UnoFeatures let's you quickly add and manage implicit package references based on the features you want to use.
          https://aka.platform.uno/singleproject-features
        -->
        <UnoFeatures> 
            Extensions;  
            Hosting;
            Navigation;  
            Material;
            MVVM;
            ThemeService;
        </UnoFeatures>
        <RootNamespace>Melodee</RootNamespace>
    </PropertyGroup>
    <ItemGroup>
      <ProjectReference Include="..\Melodee.Common\Melodee.Common.csproj" />
      <ProjectReference Include="..\Melodee.Plugins\Melodee.Plugins.csproj" />
    </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Mapster" Version="7.4.0" />
  </ItemGroup>  
    <ItemGroup>
      <None Remove="configuration.json" />
      <Content Include="configuration.json">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </Content>
    </ItemGroup>

</Project>
